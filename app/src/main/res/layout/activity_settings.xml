<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="@dimen/touch_target_min"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#000000"
        android:paddingStart="@dimen/screen_padding"
        android:paddingEnd="@dimen/screen_padding">

        <TextView
            android:id="@+id/btnSettingsBack"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="Back"
            android:textColor="#FFFFFF"
            android:textSize="@dimen/text_body"
            android:minWidth="@dimen/touch_target_min" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/settings_title"
            android:textColor="#FFFFFF"
            android:textSize="@dimen/text_body"
            android:fontFamily="sans-serif-medium" />

        <View
            android:layout_width="@dimen/touch_target_min"
            android:layout_height="1dp" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/screen_padding">

            <!-- Connection Section -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/settings_connection"
                android:textSize="@dimen/text_header"
                android:textColor="#000000"
                android:textStyle="bold"
                android:paddingBottom="8dp" />

            <!-- Connection status -->
            <TextView
                android:id="@+id/settingsConnectionStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="@dimen/text_body"
                android:textColor="#000000"
                android:paddingBottom="@dimen/screen_padding" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnReconnect"
                android:layout_width="match_parent"
                android:layout_height="@dimen/touch_target_min"
                android:text="@string/settings_reconnect"
                style="@style/Widget.PalmaMirror.Button.Secondary"
                android:textAllCaps="false" />

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="@dimen/divider_height"
                android:layout_marginTop="@dimen/section_gap"
                android:layout_marginBottom="@dimen/section_gap"
                android:background="#000000" />

            <!-- Font Size Section -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/settings_font_size"
                android:textSize="@dimen/text_header"
                android:textColor="#000000"
                android:textStyle="bold"
                android:paddingBottom="8dp" />

            <RadioGroup
                android:id="@+id/fontSizeGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <RadioButton
                    android:id="@+id/fontSmall"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/touch_target_min"
                    android:text="@string/settings_font_small"
                    android:textSize="@dimen/text_body"
                    android:textColor="#000000"
                    android:buttonTint="#000000" />

                <RadioButton
                    android:id="@+id/fontMedium"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/touch_target_min"
                    android:text="@string/settings_font_medium"
                    android:textSize="@dimen/text_body"
                    android:textColor="#000000"
                    android:buttonTint="#000000"
                    android:checked="true" />

                <RadioButton
                    android:id="@+id/fontLarge"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/touch_target_min"
                    android:text="@string/settings_font_large"
                    android:textSize="@dimen/text_body"
                    android:textColor="#000000"
                    android:buttonTint="#000000" />

                <RadioButton
                    android:id="@+id/fontXLarge"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/touch_target_min"
                    android:text="@string/settings_font_xlarge"
                    android:textSize="@dimen/text_body"
                    android:textColor="#000000"
                    android:buttonTint="#000000" />
            </RadioGroup>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="@dimen/divider_height"
                android:layout_marginTop="@dimen/section_gap"
                android:layout_marginBottom="@dimen/section_gap"
                android:background="#000000" />

            <!-- Battery Optimization -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/settings_battery_optimization"
                android:textSize="@dimen/text_header"
                android:textColor="#000000"
                android:textStyle="bold"
                android:paddingBottom="4dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/settings_battery_optimization_desc"
                android:textSize="16sp"
                android:textColor="#000000"
                android:paddingBottom="@dimen/screen_padding" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnBatteryOptimization"
                android:layout_width="match_parent"
                android:layout_height="@dimen/touch_target_min"
                android:text="@string/settings_battery_optimization"
                style="@style/Widget.PalmaMirror.Button.Secondary"
                android:textAllCaps="false" />

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="@dimen/divider_height"
                android:layout_marginTop="@dimen/section_gap"
                android:layout_marginBottom="@dimen/section_gap"
                android:background="#000000" />

            <!-- About -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/settings_about"
                android:textSize="@dimen/text_header"
                android:textColor="#000000"
                android:textStyle="bold"
                android:paddingBottom="8dp" />

            <TextView
                android:id="@+id/settingsVersion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="@dimen/text_body"
                android:textColor="#000000" />

            <!-- Bottom spacing -->
            <View
                android:layout_width="match_parent"
                android:layout_height="@dimen/section_gap" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>
