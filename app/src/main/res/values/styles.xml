<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Base E-Ink Theme: Pure black on white, no animations, no shadows -->
    <style name="Theme.PalmaMirror" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">#000000</item>
        <item name="colorPrimaryVariant">#000000</item>
        <item name="colorOnPrimary">#FFFFFF</item>
        <item name="colorSecondary">#000000</item>
        <item name="colorSecondaryVariant">#000000</item>
        <item name="colorOnSecondary">#FFFFFF</item>
        <item name="android:colorBackground">#FFFFFF</item>
        <item name="colorOnBackground">#000000</item>
        <item name="colorSurface">#FFFFFF</item>
        <item name="colorOnSurface">#000000</item>
        <item name="colorError">#000000</item>
        <item name="colorOnError">#FFFFFF</item>

        <!-- Disable all animations for e-ink -->
        <item name="android:windowAnimationStyle">@null</item>
        <item name="android:windowNoTitle">true</item>

        <!-- Status bar: black on white -->
        <item name="android:statusBarColor">#FFFFFF</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <!-- Text Styles -->
    <style name="TextAppearance.PalmaMirror.Header" parent="TextAppearance.MaterialComponents.Headline5">
        <item name="android:textSize">24sp</item>
        <item name="android:textColor">#000000</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="TextAppearance.PalmaMirror.Body" parent="TextAppearance.MaterialComponents.Body1">
        <item name="android:textSize">18sp</item>
        <item name="android:textColor">#000000</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <style name="TextAppearance.PalmaMirror.Caption" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">#000000</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <style name="TextAppearance.PalmaMirror.CallName" parent="TextAppearance.MaterialComponents.Headline3">
        <item name="android:textSize">48sp</item>
        <item name="android:textColor">#000000</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="TextAppearance.PalmaMirror.CallNumber" parent="TextAppearance.MaterialComponents.Headline5">
        <item name="android:textSize">24sp</item>
        <item name="android:textColor">#000000</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <!-- Button Styles -->
    <style name="Widget.PalmaMirror.Button.Primary" parent="Widget.MaterialComponents.Button">
        <item name="android:minHeight">48dp</item>
        <item name="android:textSize">18sp</item>
        <item name="android:textColor">#FFFFFF</item>
        <item name="backgroundTint">#000000</item>
        <item name="cornerRadius">8dp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="Widget.PalmaMirror.Button.Secondary" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:minHeight">48dp</item>
        <item name="android:textSize">18sp</item>
        <item name="android:textColor">#000000</item>
        <item name="strokeColor">#000000</item>
        <item name="strokeWidth">2dp</item>
        <item name="cornerRadius">8dp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="Widget.PalmaMirror.Button.CallAccept" parent="Widget.MaterialComponents.Button">
        <item name="android:minHeight">80dp</item>
        <item name="android:textSize">48sp</item>
        <item name="android:textColor">#FFFFFF</item>
        <item name="backgroundTint">#000000</item>
        <item name="cornerRadius">0dp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="Widget.PalmaMirror.Button.CallReject" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:minHeight">80dp</item>
        <item name="android:textSize">48sp</item>
        <item name="android:textColor">#000000</item>
        <item name="strokeColor">#000000</item>
        <item name="strokeWidth">2dp</item>
        <item name="cornerRadius">0dp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <!-- Card Style -->
    <style name="Widget.PalmaMirror.Card" parent="Widget.MaterialComponents.CardView">
        <item name="cardElevation">0dp</item>
        <item name="cardCornerRadius">8dp</item>
        <item name="strokeColor">#000000</item>
        <item name="strokeWidth">2dp</item>
        <item name="cardBackgroundColor">#FFFFFF</item>
    </style>

</resources>
